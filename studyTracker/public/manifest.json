{
    "manifest_version": 3, 
    "version": "1.0.0",
    "name":"Study Tracker",
    "action":{
        "default_popup":"popup.html",
        "default_title":"Study Tracker"

    },
    "permissions":[
        "scripting",
        "storage"
    ],
    "host_permissions":[
        "http://*/*",
        "https://*/*"
    ],
    "background":{
        "service_worker":"background.js",
        "type":"module"
    },
    "web_accessible_resources": [
  {
    "resources": ["assets/fonts/*"],
    "matches": ["<all_urls>"]
  }
]




}